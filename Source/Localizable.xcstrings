    "'%@' already exists. All annotations from '%@' will be merged into '%@'." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%1$@' موجود بالفعل. سيتم دمج جميع التعليقات من '%2$@' في '%3$@'."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%1$@' already exists. All annotations from '%2$@' will be merged into '%3$@'."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "'%1$@' sudah ada. Semua anotasi dari '%2$@' akan digabungkan ke dalam '%3$@'."
          }
        }
      }
    },
    "\"%@\" and all its contents will be permanently deleted." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم حذف \"%@\" وجميع محتوياته نهائيًا."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" dan semua isinya akan dihapus secara permanen."
          }
        }
      }
    },
