    "ID %@ already has %lld local annotations, possibly from CloudKit synchronization with another device for a different book. Proceed only if you are sure these annotations belong to this book." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المعرف %1$@ يحتوي بالفعل على %2$lld تعليقاً محلياً، ربما من مزامنة CloudKit مع جهاز أخر لكتاب مختلف. تابع فقط إذا كنت متأكداً من أن هذه التعليقات تخص هذا الكتاب."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ID %1$@ already has %2$lld local annotations, possibly from CloudKit synchronization with another device for a different book. Proceed only if you are sure these annotations belong to this book."
