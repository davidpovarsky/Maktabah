    "annotationsMoveFolderFileExistsDesc" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التعليقات التوضيحية موجودة بالفعل في مجلد الوجهة. هل ترغب في الاحتفاظ بها (وحذف القديمة) أو الكتابة فوقها بالقديمة؟"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Annotations already exist in the destination folder. Would you like to keep them (and delete the old ones) or overwrite them with the old ones?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anotasi sudah ada di folder tujuan. Apakah Anda ingin menggunakan anotasi di folder tujuan (dan menghapus yang lama) atau menimpa anotasi di folder tujuan dengan yang lama?"
          }
        }
      }
    },
    "anyWordsSearchDesc" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يبحث عن السجلات التي تحتوي على واحدة على الأقل من الكلمات أو العبارات المفصولة بفاصلة (،). تُدرج في النتائج السجلاتُ المطابقة لأي من المدخلات.\n(مثال: الزكاة، زكاة)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Searches for records containing at least one of the words or phrases separated by a comma (,). Records matching any of the entries will be included in the results.\n(e.g., زكاة ,الزكاة)"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mencari data yang mengandung setidaknya satu kata atau frasa yang dipisahkan dengan koma (,). Data yang cocok dengan salah satu entri akan ditampilkan dalam hasil pencarian.\n(contoh: زكاة ,الزكاة)"
          }
        }
      }
    },
    "anyWordsSearchTitle" : {
      "localizations" : {
        "ar" : {
