      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يبحث عن الكلمات المفصولة بفاصلة (،). لا يشترط أن تكون الكلمات متجاورة أو بالترتيب المحدد.\n\n(مثال: صلاة الجماعة، المأموم المسبوق)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Searches for words separated by a comma (,). The words do not need to be adjacent or in the order specified.\n(e.g., صلاة الجماعة, المأموم المسبوق)"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mencari kata-kata yang dipisahkan oleh sebuah koma (,). Kata-kata tersebut tidak perlu berdampingan atau dalam urutan yang ditentukan. (contoh: صلاة الجماعة, المأموم المسبوق)"
          }
        }
